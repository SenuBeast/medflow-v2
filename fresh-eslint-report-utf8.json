    if (!isInitialized || isLoading) {\r\n        return (\r\n            <div className=\"min-h-screen bg-slate-50 flex items-center justify-center\">\r\n                <Loader2 className=\"w-8 h-8 animate-spin text-blue-500\" />\r\n            </div>\r\n        );\r\n    }\r\n\r\n    if (!user) {\r\n        return <Navigate to=\"/login\" state={{ from: location }} replace />;\r\n    }\r\n\r\n    if (!isTwoFactorVerified) {\n        const next = `${location.pathname}${location.search}`;\n        return <Navigate to={`/verify-2fa?next=${encodeURIComponent(next)}`} replace state={{ from: location }} />;\n    }\n\r\n    return <>{children}</>;\r\n}\r\n\r\ninterface RouteGuardProps {\r\n    permission: PermissionKey;\r\n    children: ReactNode;\r\n}\r\n\r\nexport function RouteGuard({ permission, children }: RouteGuardProps) {\r\n    const { isInitialized, isLoading } = useAuthStore();\r\n\r\n    if (!isInitialized || isLoading) {\r\n        return <LoadingScreen />;\r\n    }\r\n\r\n    const canAccess = useHasPermission(permission);\r\n\r\n    if (!canAccess) {\r\n        return <Navigate to=\"/no-access\" replace />;\r\n    }\r\n\r\n    return <>{children}</>;\r\n}\r\n\r\ninterface PermissionGuardProps {\r\n    permission: PermissionKey;\r\n    children: ReactNode;\r\n    fallback?: ReactNode;\r\n}\r\n\r\nexport function PermissionGuard({\r\n    permission,\r\n    children,\r\n    fallback = null,\r\n}: PermissionGuardProps) {\r\n    const canAccess = useHasPermission(permission);\r\n\r\n    if (!canAccess) {\r\n        return <>{fallback}</>;\r\n    }\r\n\r\n    return <>{children}</>;\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"E:\\Projects\\MedFlow-v2\\src\\components\\dashboard\\ActivityFeed.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"E:\\Projects\\MedFlow-v2\\src\\components\\dashboard\\AlertsPanel.tsx","messages":[],"supp