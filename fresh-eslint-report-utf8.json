                            <div className=\"flex justify-between items-start mb-1\">\r\n                                    <span className=\"text-sm font-semibold text-text-main\">\r\n                                        ${sale.total.toFixed(2)}\r\n                                    </span>\r\n                                    <span className=\"text-xs text-text-dim flex items-center gap-1\">\r\n                                        <CheckCircle size={10} className=\"text-success\" />\r\n                                        {formatDistanceToNow(new Date(sale.created_at), { addSuffix: true })}\r\n                                    </span>\r\n                                </div>\r\n                                <div className=\"text-xs text-text-sub flex justify-between\">\r\n                                    <span>#{sale.invoice_number}</span>\r\n                                    <span>{(sale as any).seller?.full_name || 'Staff'}</span>\r\n                                </div>\r\n                            </div>\r\n                        ))}\r\n                    </div>\r\n                )}\r\n            </div>\r\n        </Card>\r\n    );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"E:\\Projects\\MedFlow-v2\\src\\components\\dashboard\\TopProductsList.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"E:\\Projects\\MedFlow-v2\\src\\components\\inventory\\BulkImportModal.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"E:\\Projects\\MedFlow-v2\\src\\components\\inventory\\ItemBatchForm.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"E:\\Projects\\Med